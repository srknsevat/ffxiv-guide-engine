# API
API_PORT=3001
JWT_SECRET=change-me
INTERNAL_API_TOKEN=change-me-internal
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_USER=ffxiv
POSTGRES_PASSWORD=ffxiv
POSTGRES_DB=ffxiv
SCHEMA_SYNC=true
SEED_DEMO_GUIDES=true
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Web / Admin (Next.js)
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# Coolify production example
# NEXT_PUBLIC_SITE_URL=https://ffxiv.example.com
# NEXT_PUBLIC_API_URL=https://api.ffxiv.example.com

# Scraper
SCRAPER_ENABLED=true
API_BASE_URL=http://localhost:3001
REDIS_URL=redis://localhost:6379
SCRAPER_POLL_INTERVAL_MS=2000
SCRAPER_MAX_ATTEMPTS=3
SCRAPER_RETRY_BACKOFF_MS=3000
SCRAPER_WORKER_CONCURRENCY=2
SCRAPER_FETCH_TIMEOUT_MS=15000
SCRAPER_FETCH_MAX_RETRIES=2
LODESTONE_NEWS_ENABLED=true

# Storage (future)
STORAGE_PROVIDER=local
